<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Multi-Lane Sachet Packing — Executive Presentation</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #EEE8DE;
    --bg2:      #E4DDD2;
    --navy:     #1B3A5C;
    --navy2:    #254E7A;
    --accent:   #2E7BB4;
    --accent2:  #1A5F96;
    --amber:    #C87820;
    --red:      #C0392B;
    --green:    #1E7A4A;
    --text:     #1B2B3A;
    --text2:    #3D5166;
    --muted:    #7A8FA3;
    --card:     #F7F3ED;
    --card2:    #EDE7DC;
    --border:   #C8BFAF;
    --border2:  #A8B8C8;
    --font-th:  'IBM Plex Sans Thai', sans-serif;
    --font-mono:'IBM Plex Mono', monospace;
  }

  html, body { width:100%; height:100%; background:var(--bg); color:var(--text); font-family:var(--font-th); overflow:hidden; }

  #deck { width:100%; height:100vh; position:relative; overflow:hidden; }

  .slide {
    position:absolute; inset:0; display:flex; flex-direction:column;
    padding:48px 68px 42px;
    opacity:0; pointer-events:none; transform:translateY(36px);
    transition:opacity .42s ease, transform .42s ease;
  }
  .slide.active { opacity:1; pointer-events:all; transform:none; }
  .slide.exit-up   { transform:translateY(-36px); opacity:0; }
  .slide.exit-down { transform:translateY(36px);  opacity:0; }

  #progress-bar { position:fixed; top:0; left:0; height:3px; background:var(--accent); transition:width .4s ease; z-index:99; }
  #counter { position:fixed; bottom:20px; right:28px; font-family:var(--font-mono); font-size:12px; color:var(--muted); z-index:99; }

  .eyebrow { font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--accent2); font-weight:700; margin-bottom:8px; }
  .slide-title { font-size:34px; font-weight:700; line-height:1.2; color:var(--navy); }
  .slide-title span { color:var(--accent); }
  .slide-sub { font-size:14px; color:var(--text2); margin-top:7px; font-weight:300; }
  .divider { height:2px; margin:14px 0; width:80px; background:linear-gradient(90deg, var(--accent) 0%, transparent 100%); }

  .tag { font-size:10px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; padding:3px 9px; border-radius:4px; display:inline-block; width:fit-content; }
  .tag-old { background:#F5E8E8; color:var(--red);   border:1px solid #DDB8B8; }
  .tag-new { background:#E0EDF7; color:var(--accent2); border:1px solid #A8C8E4; }
  .tag-saving { background:#E0F0EA; color:var(--green); border:1px solid #A0CCB8; }

  /* ── SLIDE 1 — COVER ── */
  #s1 { justify-content:center; background:linear-gradient(135deg, #1B3A5C 0%, #254E7A 55%, #2E6FA0 100%); }
  #s1 * { color:#E8F0F8; }
  #s1 .eyebrow { color:#7EC8F0; }
  #s1 .cover-title em { color:#7EC8F0; font-style:normal; }
  #s1 .cover-meta-item { color:#9AB8D4; }
  #s1 .cover-meta-item strong { color:#E8F0F8; display:block; font-size:15px; margin-bottom:2px; }
  #s1 .cover-footer { color:#5A80A0; }
  .cover-tag { display:inline-block; background:rgba(126,200,240,.15); color:#A8D8F0; border:1px solid rgba(126,200,240,.3); font-size:10px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; padding:4px 13px; border-radius:4px; margin-bottom:24px; }
  .cover-title { font-size:50px; font-weight:700; line-height:1.12; max-width:760px; }
  .cover-sub { font-size:17px; font-weight:300; margin:12px 0 0; opacity:.7; }
  .cover-meta { margin-top:44px; display:flex; gap:36px; }
  .cover-accent { position:absolute; right:0; top:0; bottom:0; width:4px; background:linear-gradient(180deg,#7EC8F0 0%,#2E7BB4 60%,transparent 100%); }
  .cover-footer { font-size:11px; margin-top:auto; text-align:right; }

  /* ── CARDS ── */
  .crd { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:18px 20px; }
  .crd.hi { border-color:var(--accent); border-width:2px; }
  .crd.hi-g { border-color:var(--green); border-width:2px; background:#F0F8F4; }
  .crd-lbl { font-size:10px; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); margin-bottom:6px; }
  .crd-val { font-family:var(--font-mono); font-size:22px; font-weight:700; }
  .crd-val.blue  { color:var(--accent2); }
  .crd-val.amber { color:var(--amber); }
  .crd-val.green { color:var(--green); }
  .crd-sub { font-size:11px; color:var(--muted); margin-top:3px; }

  .spec-row { display:flex; gap:8px; flex-wrap:wrap; }
  .pill { background:var(--card2); border:1px solid var(--border); border-radius:5px; padding:4px 10px; font-size:12px; color:var(--text2); }
  .pill strong { color:var(--navy); }

  /* ── TABLE ── */
  .tbl { width:100%; border-collapse:collapse; }
  .tbl th { text-align:left; font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); padding:4px 8px; border-bottom:1px solid var(--border); }
  .tbl td { font-size:13px; color:var(--text2); padding:6px 8px; border-bottom:1px solid var(--card2); }
  .tbl td.mono { font-family:var(--font-mono); }
  .tbl tr.ttl td { color:var(--navy); font-weight:700; border-top:1px solid var(--border); }

  /* ── LANE VIZ ── */
  .lane-wrap { display:flex; gap:4px; align-items:center; }
  .lb { width:15px; height:26px; border-radius:3px; background:var(--card2); border:1px solid var(--border); }
  .lb.r { background:#DDA0A0; border-color:var(--red); }
  .lb.b { background:rgba(255,255,255,.35); border-color:transparent; }

  /* ── SAVING BANNER ── */
  .s-banner { background:linear-gradient(135deg,#E0EDF7,#D0E4F0); border:1px solid var(--border2); border-radius:10px; padding:16px 22px; display:flex; align-items:center; justify-content:space-between; }
  .s-banner.g { background:linear-gradient(135deg,#E0F0EA,#CCE8DC); border-color:#90C8AA; }
  .s-banner-lbl { font-size:12px; color:var(--text2); }
  .s-banner-sub { font-size:11px; color:var(--muted); margin-top:2px; }
  .s-banner-val { font-family:var(--font-mono); font-size:30px; font-weight:700; }

  /* ── PAYBACK ── */
  .pb-wrap { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:18px 22px; }
  .pb-lbl { font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); margin-bottom:10px; }
  .pb-track { height:16px; background:var(--card2); border-radius:8px; overflow:hidden; }
  .pb-fill { height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2)); border-radius:8px; transition:width 1s ease .3s; }
  .pb-ticks { position:relative; height:22px; margin-top:2px; }
  .pbt { position:absolute; transform:translateX(-50%); font-size:10px; font-family:var(--font-mono); color:var(--muted); top:4px; }
  .pbt.hi { color:var(--accent2); font-weight:700; }
</style>
</head>
