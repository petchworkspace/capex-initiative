<script>
  const slides = Array.from(document.querySelectorAll('.slide'));
  const total  = slides.length;
  let current  = 0;

  function goTo(idx, dir) {
    if (idx < 0 || idx >= total) return;
    const prev = slides[current];
    prev.classList.remove('active');
    prev.classList.add(dir === 1 ? 'exit-up' : 'exit-down');
    setTimeout(() => prev.classList.remove('exit-up','exit-down'), 500);
    current = idx;
    slides[current].classList.add('active');
    document.getElementById('counter').textContent = `${current + 1} / ${total}`;
    document.getElementById('progress-bar').style.width = ((current + 1) / total * 100) + '%';
    if (current === 9) {
      const f = document.querySelector('.pb-fill');
      if (f) { f.style.width = '0%'; setTimeout(() => f.style.width = '40.8%', 120); }
    }
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') goTo(current + 1,  1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   goTo(current - 1, -1);
  });

  let tx = null;
  document.addEventListener('touchstart', e => { tx = e.touches[0].clientX; });
  document.addEventListener('touchend',   e => {
    if (tx === null) return;
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 50) goTo(current + (dx < 0 ? 1 : -1), dx < 0 ? 1 : -1);
    tx = null;
  });

  document.getElementById('progress-bar').style.width = (1/total*100) + '%';
</script>
</body>
</html>
